{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "YOUR-APP-ID-HERE",
  "packageName": "com.office.lunchorder",
  "developer": {
    "name": "Your Company",
    "websiteUrl": "https://www.yourcompany.com",
    "privacyUrl": "https://www.yourcompany.com/privacy",
    "termsOfUseUrl": "https://www.yourcompany.com/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "Lunch Order",
    "full": "Office Lunch Ordering System"
  },
  "description": {
    "short": "Streamline office lunch ordering",
    "full": "A comprehensive tool for ordering lunch as a team. Select from restaurant menus, set defaults, and keep track of order history."
  },
  "accentColor": "#60A917",
  "bots": [
    {
      "botId": "YOUR-BOT-ID-HERE",
      "scopes": [
        "personal",
        "team"
      ],
      "commandLists": [
        {
          "scopes": [
            "personal",
            "team"
          ],
          "commands": [
            {
              "title": "order",
              "description": "Create a new lunch order"
            },
            {
              "title": "mydefault",
              "description": "Set your default order for a restaurant"
            },
            {
              "title": "history",
              "description": "View your order history"
            },
            {
              "title": "help",
              "description": "Show available commands"
            }
          ]
        }
      ]
    }
  ],
  "staticTabs": [
    {
      "entityId": "lunchorder",
      "name": "Lunch Order",
      "contentUrl": "https://YOUR-APP-URL.azurewebsites.net/",
      "websiteUrl": "https://YOUR-APP-URL.azurewebsites.net/",
      "scopes": [
        "personal"
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "YOUR-APP-URL.azurewebsites.net"
  ],
  "webApplicationInfo": {
    "id": "YOUR-APP-ID-HERE",
    "resource": "api://YOUR-APP-URL.azurewebsites.net/YOUR-APP-ID-HERE"
  }
}
