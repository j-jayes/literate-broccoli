# Azure Configuration
AZURE_SUBSCRIPTION_ID=e9b64842-3c87-4665-ad56-86ae7c20fe4b
AZURE_RESOURCE_GROUP=rg-lunch-ordering-prod
AZURE_LOCATION=eastus

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/lunch_ordering
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=86400
REDIS_PASSWORD=

# MS Teams Configuration
TEAMS_BOT_ID=your-bot-id
TEAMS_BOT_PASSWORD=your-bot-password
TEAMS_TENANT_ID=your-tenant-id
TEAMS_APP_ID=your-app-id

# API Configuration
API_BASE_URL=http://localhost:8000
API_SECRET_KEY=your-secret-key-change-this-in-production
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Azure Key Vault (for production)
KEY_VAULT_NAME=kv-lunch-ordering
KEY_VAULT_URI=https://kv-lunch-ordering.vault.azure.net/

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here
APPLICATION_INSIGHTS_KEY=your-instrumentation-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Web Scraping
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SELENIUM_DRIVER_PATH=/usr/local/bin/chromedriver

# Environment
ENVIRONMENT=development
DEBUG=True
