# === Azure Bot Service ===
BOT_APP_ID=your-bot-app-id-guid
BOT_APP_PASSWORD=your-bot-app-password

# === LLM Providers (same as parent project .env) ===
# Azure OpenAI (primary)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# OpenAI (fallback)
OPENAI_API_KEY=

# Google Gemini (required for search + LLM fallback)
GOOGLE_API_KEY=

# Server port
PORT=3978
